# pdf-generator (port 8084): renders the invoice template from JSON
# data. A valid request returns raw PDF bytes (magic number %PDF).

GET http://localhost:8084/health
HTTP 200
[Asserts]
jsonpath "$.status" == "ok"
jsonpath "$.service" == "pdf-generator"

POST http://localhost:8084/generate
Content-Type: application/json
{
  "invoice_number": "INV-HURL-001",
  "date": "2026-07-12",
  "company": {"name": "Hurl Testing Co", "address": "1 Test Lane", "phone": "555-0100", "email": "billing@example.com"},
  "customer": {"name": "Jane Smith", "company": "Acme", "address": "2 Client Rd"},
  "subtotal": "$1,750.00",
  "tax": "$157.50",
  "total": "$1,907.50",
  "notes": "Generated by the integration test suite"
}
HTTP 200
[Asserts]
header "Content-Type" == "application/pdf"
bytes startsWith hex,25504446;

# malformed JSON is a 400
POST http://localhost:8084/generate
Content-Type: application/json
`this is not json`
HTTP 400
[Asserts]
jsonpath "$.error" exists
